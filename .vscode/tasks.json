{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Log Filter GUI (current file)",
      "type": "process",
      "command": "py",
      "args": [
        "-3.13",
        "${workspaceFolder}\\main.py",
        "--input-file",
        "${file}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "LogSieve – Publish stable",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\publish_stable.ps1"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}